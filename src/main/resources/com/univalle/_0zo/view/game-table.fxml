<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.univalle._0zo.controller.TableController">

    <!-- Arriba: jugadores máquina -->
    <top>
        <HBox alignment="CENTER" spacing="40.0">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label fx:id="machine1Label" text="Máquina 1" style="-fx-font-size: 14px;" />
            <Label fx:id="machine2Label" text="Máquina 2" style="-fx-font-size: 14px;" />
            <Label fx:id="machine3Label" text="Máquina 3" style="-fx-font-size: 14px;" />
        </HBox>
    </top>

    <!-- Centro: mesa -->
    <center>
        <VBox alignment="CENTER" spacing="10.0">
            <Label text="MESA" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
            <Label fx:id="tableCardLabel" text="Carta: ???" style="-fx-font-size: 16px;" />
            <Label fx:id="tableSumLabel" text="Suma: 0" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        </VBox>
    </center>

    <!-- Abajo: mano del jugador humano -->
    <bottom>
        <VBox alignment="CENTER" spacing="10.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <Label text="Tu mano" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
            <HBox fx:id="playerHandBox" alignment="CENTER" spacing="10.0" />
        </VBox>
    </bottom>

</BorderPane>
